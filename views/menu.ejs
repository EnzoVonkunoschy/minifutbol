<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mini Futbol - Menú</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="Estilo/menu.css">
</head>
<body>
     <div class="logo-container p-3">
  <img src="/Estilo/logo.png" alt="Logo Mini Futbol" class="logo-img">
</div>
  <div class="header">
<div class="field-wrapper d-flex justify-content-center">
  <img src="/Estilo/cancha.jpg" alt="Cancha de Fútbol" class="field-img">
</div>
  </div>

  <div class="menu-section">

    <form action="<%=url%>/clientes" method="POST">
      <input type="hidden" name="token" value="<%=token%>">
      <button type="submit" class="menu-item w-100 border-0">
        <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="white" class="bi bi-person" viewBox="0 0 16 16">
          <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
          <path d="M2 13s-1 0-1-1 1-4 7-4 7 3 7 4-1 1-1 1H2z"/>
        </svg>
        REGISTRAR CLIENTE
      </button>
    </form>

    <form action="<%=url%>/turnos" method="POST">
      <input type="hidden" name="token" value="<%=token%>">
      <button type="submit" class="menu-item w-100 border-0">
        <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="white" class="bi bi-calendar-plus" viewBox="0 0 16 16">
          <path d="M8 7.5a.5.5 0 0 1 .5.5V10H10a.5.5 0 0 1 0 1H8.5v1.5a.5.5 0 0 1-1 0V11H6a.5.5 0 0 1 0-1h1.5V8a.5.5 0 0 1 .5-.5z"/>
          <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z"/>
        </svg>
        ASIGNAR TURNO
      </button>
    </form>

    <form action="/login.ejs" method="POST" class="text-center">
      <input type="hidden" name="token" value="<%=token%>">
      <button type="submit" class="btn btn-link logout-btn text-decoration-none">Cerrar sesión</button>
    </form>

  </div>

</body>
</html>
