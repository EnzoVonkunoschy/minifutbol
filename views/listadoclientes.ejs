<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Listado de Clientes</title>
  <link rel="stylesheet" href="/Estilo/registrarcli.css">
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

  <div class="logo-container">
    <img src="/Estilo/logo.png" alt="Logo Mini Futbol" class="logo-img">
  </div>

  <div class="titulo-header text-center">
    <h1>Listado de Clientes</h1>
  </div>

  <div class="registro-container">
    <table style="width:100%; border-collapse: collapse;">
      <thead>
        <tr style="background-color:#1b3b1a; color:white;">
          <th style="padding: 10px;">Nro Cliente</th>
          <th style="padding: 10px;">Nombre</th>
          <th style="padding: 10px;">DNI</th>
          <th style="padding: 10px;">Teléfono</th>
          <th style="padding: 10px;">Eliminar</th>
        </tr>
      </thead>
      <tbody>
      <% for (let i = 0; i < clientes.length; i++) { 
     if (clientes[i]) { %>
  <tr style="text-align:center;">
    <td><%= i+1 %></td>
    <td><%= clientes[i].nombre %></td>
    <td><%= clientes[i].dni %></td>
    <td><%= clientes[i].telefono %></td>
    <td>
      <form action="/eliminarCliente" method="post" style="margin: 0;" class="form-eliminar">
        <input type="hidden" name="token" value="<%= token %>">
        <input type="hidden" name="dni" value="<%= clientes[i].dni %>">
        <!-- Botón que abre el modal -->
        <button type="button" class="btn-registrar btn-eliminar" style="font-size: 14px;" data-bs-toggle="modal" data-bs-target="#confirmModal">
          Eliminar
        </button>
      </form>
    </td>
  </tr>
<%   } 
   } %>

      </tbody>
    </table>

    <br>

  </div>
  <form action="<%= url %>/menuGeneral" method="POST" class="text-center">
      <input type="hidden" name="token" value="<%= token %>">
      <button type="submit" class="btn-volver">Volver</button>
    </form>

 <!-- Modal Bootstrap -->
  <div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header bg-verde">
          <h5 class="modal-title">Confirmar eliminación</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          ¿Está seguro que desea eliminar este cliente?
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="button" id="btnConfirmar" class="btn btn-danger">Eliminar</button>

        </div>
      </div>
    </div>
  </div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let formAEliminar = null;

    // Guardar el formulario del botón presionado
    document.querySelectorAll(".btn-eliminar").forEach(btn => {
      btn.addEventListener("click", function() {
        formAEliminar = this.closest("form");
      });
    });

    // Confirmar eliminación
    document.getElementById("btnConfirmar").addEventListener("click", function() {
      if (formAEliminar) {
        formAEliminar.submit();
      }
    });
  </script>

</body>
</html>
