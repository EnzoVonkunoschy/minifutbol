<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrar Turno</title>
     <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Tu CSS personalizado -->
  <link rel="stylesheet" href="/Estilo/registrarcli.css">
   <link rel="stylesheet" href="Estilo/menu.css">
</head>

<body>
  <div class="logo-container p-3">
  <img src="/Estilo/logo.png" alt="Logo Mini Futbol" class="logo-img">
</div>

    <div class="titulo-header text-center">
    <h1>Registrar turno</h1>
  </div>
    
     <div class="registro-container">
    <form action='<%=url%>/nuevoturno' method="POST">
      <input type="date" name="dia" placeholder="Día del turno" required>
      <input type="number" name="turno" placeholder="Turno" required>
      
      <select name="libre" required>
        <option value=""> Estado </option>
        <option value="libre">Libre</option>
        <option value="ocupado">Ocupado</option>
      </select>
      
      <input type="hidden" name="token" value="lkjrt4v3wmtiqoprmmor98">
      <button type="submit" class="btn-registrar">Registrar</button>
    </form>
  </div>
     
