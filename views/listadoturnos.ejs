<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/Estilo/registrarcli.css">
    <title>Lista de Turnos</title>
</head>
<body>
<div class="logo-container">
    <img src="/Estilo/logo.png" alt="Logo Mini Futbol" class="logo-img">
  </div>

  <div class="titulo-header text-center">
    <h1>Lista de turnos</h1>
  </div>
<h1>Lista de turnos</h1>

<div class="registro-container">
  <table style="width:100%; border-collapse: collapse;">
    <thead>
      <tr style="background-color:#1b3b1a; color:white;">
        <th style="padding: 10px;">N° de lista</th>
        <th style="padding: 10px;">Día</th>
        <th style="padding: 10px;">N° de Turno</th>
        <th style="padding: 10px;">Cliente</th>
        <th style="padding: 10px;">Eliminar</th>
      </tr>
    </thead>
    <tbody>
      <% for (let i = 0; i < turnos.length; i++) { 
         if (turnos[i] && turnos[i].cliente) { %>
        <tr style="text-align:center;">
          <td><%= i + 1 %></td>
          <td><%= turnos[i].dia %></td>
          <td><%= turnos[i].hora %></td>
          <td><%= turnos[i].cliente.nombre %></td>
          <td>
            <form action="/eliminarTurno" method="post" style="margin: 0;">
              <input type="hidden" name="token" value="<%= token %>">
              <input type="hidden" name="dia" value="<%= turnos[i].dia %>">
              <input type="hidden" name="turno" value="<%= turnos[i].hora %>">
              <button type="button" class="btn-registrar btn-eliminar" style="font-size: 14px;" data-bs-toggle="modal" data-bs-target="#confirmModal">
                Eliminar
              </button>
            </form>
          </td>
        </tr>
      <% } } %>
    </tbody>
  </table>

  <br>
</div>
    <form action="<%= url %>/menuGeneral" method="POST" class="text-center">
      <input type="hidden" name="token" value="<%= token %>">
      <button type="submit" class="btn-volver">Volver</button>
    </form>
    <!-- Modal Bootstrap -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-verde">
        <h5 class="modal-title">Confirmar eliminación</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        ¿Está seguro que desea eliminar este turno?
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" id="btnConfirmar" class="btn btn-danger">Eliminar</button>
      </div>
    </div>
  </div>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  let formAEliminar = null;

  // Guardar el formulario del botón presionado
  document.querySelectorAll(".btn-eliminar").forEach(btn => {
    btn.addEventListener("click", function() {
      formAEliminar = this.closest("form");
    });
  });

  // Confirmar eliminación
  document.getElementById("btnConfirmar").addEventListener("click", function() {
    if (formAEliminar) {
      formAEliminar.submit();
    }
  });
</script>
</body>
</html>