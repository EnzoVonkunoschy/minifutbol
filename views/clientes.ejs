<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Minifutbo iES-9024</h1>
    
    <form action='<%=url%>/api/clientes' method="POST" id="clientes">
        <p><label>Nombre:&nbsp;  </label><input type="text"   name="nombre"   id="nombre"   ></p>
        <p><label>Dni:&nbsp;     </label><input type="text"   name="dni"      id="dni"      ></p>
        <p><label>Telefono:&nbsp;</label><input type="number" name="telefono" id= "telefono"></p>
        <input type="hidden"  name="token" value="lkjrt4v3wmtiqoprmmor98">
        <input type="submit" value="Agregar Cliente">
    </form> 
    <br>
    <form action="<%=url%>/menuGeneral" method="POST">
        <input type="hidden" name="token" value="<%=token%>">
        <input type="submit" value="Volver">
    </form>

    <script>
            document.getElementById('clientes').addEventListener('submit', function(event){
                const nombre = document.getElementById('nombre').value.trim();
                const dni = document.getElementById('dni').value.trim();
                const telefono = document.getElementById('telefono').value.trim();

                if (!nombre || !dni  || !telefono){
                    alert("deber completar todos los campos")
                    event.preventDefault()
                }
            })
        </script>
</body>
</html>