<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Registrar Cliente</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/Estilo/menu.css" />
  
</head>
<body>

  <!-- Header con logo y título -->
  <div class="header">
<div class="logo-container p-3">
  <img src="/Estilo/logo.png" alt="Logo Mini Futbol" class="logo-img">
</div>
<h1>Registrar Cliente</h1>
</div>

  <!-- Formulario -->
  <div class="menu-section">
    <form action="<%= url %>/api/clientes" method="POST">
      <div class="menu-item">
        <input type="text" name="nombre" placeholder="Nombre completo" required>
      </div>
      <div class="menu-item">
        <input type="text" name="dni" placeholder="DNI" required>
      </div>
      <div class="menu-item">
        <input type="number" name="telefono" placeholder="Teléfono" required>
      </div>

      <input type="hidden" name="token" value="lkjrt4v3wmtiqoprmmor98">

      <button type="submit" class="submit-btn">Registrar</button>
    </form>

    <p class="logout-btn"><a href="/menu">Volver</a></p>
  </div>

</body>
</html>
